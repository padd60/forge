{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend AI code harness — enforces FSD, DDD, Clean Architecture, Clean Code, and CQRS via Planner/Generator/Evaluator pipeline.",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "seed:examples": "pnpm --filter @forge/cli build && tsx scripts/seed-examples.mts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@forge/cli": "workspace:*",
    "@types/node": "^20.12.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
