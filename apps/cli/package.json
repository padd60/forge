{
  "name": "@forge/cli",
  "version": "0.1.0",
  "description": "npx entry point for forge — wizard, init, add, check, eval commands.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "forge": "./dist/index.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@forge/core": "workspace:*",
    "@forge/module-clean-arch": "workspace:*",
    "@forge/module-clean-code": "workspace:*",
    "@forge/module-cqrs": "workspace:*",
    "@forge/module-ddd": "workspace:*",
    "@forge/module-fsd": "workspace:*",
    "@forge/schemas": "workspace:*",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@forge/eslint-plugin-forge": "workspace:*",
    "@types/node": "^20.12.0",
    "eslint": "^9.15.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
