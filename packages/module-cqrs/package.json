{
  "name": "@forge/module-cqrs",
  "version": "0.1.0",
  "description": "CQRS mapping module for forge — entities layer is the read model, features layer owns commands.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "skills", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@forge/core": "workspace:*",
    "@forge/eslint-plugin-forge": "workspace:*",
    "@forge/module-fsd": "workspace:*",
    "@forge/schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
