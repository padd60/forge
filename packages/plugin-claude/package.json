{
  "name": "@forge-kit-dev/plugin-claude",
  "version": "0.1.0",
  "description": "Claude Code plugin bundle — slash commands, skills, agents for forge.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    ".claude-plugin",
    "agents",
    "commands",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-skills.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "sync-skills": "node scripts/sync-skills.mjs",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@forge-kit-dev/module-clean-arch": "workspace:*",
    "@forge-kit-dev/module-clean-code": "workspace:*",
    "@forge-kit-dev/module-cqrs": "workspace:*",
    "@forge-kit-dev/module-ddd": "workspace:*",
    "@forge-kit-dev/module-fsd": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
