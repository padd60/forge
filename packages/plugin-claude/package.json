{
  "name": "@forge/plugin-claude",
  "version": "0.1.0",
  "description": "Claude Code plugin bundle — slash commands, skills, agents for forge.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    ".claude-plugin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-skills.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "sync-skills": "node scripts/sync-skills.mjs",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@forge/module-clean-arch": "workspace:*",
    "@forge/module-clean-code": "workspace:*",
    "@forge/module-cqrs": "workspace:*",
    "@forge/module-ddd": "workspace:*",
    "@forge/module-fsd": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
